# Attesta — variables de entorno
# Copia este archivo a `.env.local` y rellena con los valores de tu proyecto Supabase.
# Sin estas variables, la app funciona en MODO DEMO con datos de ejemplo.

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Solo servidor. NUNCA lo expongas en el cliente ni lo subas al repo.
# (Se usa para tareas administrativas puntuales; opcional para el MVP.)
SUPABASE_SERVICE_ROLE_KEY=

# --- Foso automatizado (Capa 7) — solo servidor, opcional ---
# Secreto compartido para el cron del Vigía/Analista (Vercel Cron → Bearer).
CRON_SECRET=

# Fase B — el Analista (RAG). Sin estas llaves, el Analista degrada a fallback
# (no enriquece) y el resto de la app funciona igual.
# Embeddings (https://www.voyageai.com → API Keys; 200M tokens gratis)
VOYAGE_API_KEY=
# Drafting del Analista — endpoint compatible con OpenAI (function calling).
# Por defecto NVIDIA NIM (gratis, https://build.nvidia.com → API key `nvapi-...`).
# Alternativas: Groq (https://console.groq.com), OpenRouter, etc.
ANALISTA_API_KEY=
# Opcionales (tienen default a NVIDIA NIM + Llama 3.3 70B):
# ANALISTA_BASE_URL=https://integrate.api.nvidia.com/v1
# ANALISTA_MODEL=meta/llama-3.3-70b-instruct
